{
  "apiKeyHelper": "/home/roozbeh/bin/generate-auth-anthropic",
  "env": {
    "ANTHROPIC_BASE_URL": "https://openrouter.ai/api",
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "0",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek/deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek/deepseek-v4-flash",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek/deepseek-v4-pro"
  },
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(git log:*)",
      "Bash(go get:*)",
      "Bash(go mod tidy:*)",
      "Bash(go mod vendor:*)",
      "Bash(find:*)",
      "Bash(go list:*)",
      "Bash(make lint-ci:*)",
      "Bash(go test:*)",
      "Bash(git fetch:*)",
      "Bash(done)",
      "Bash(cat:*)",
      "Bash(go doc:*)",
      "Bash(git ls-tree:*)",
      "Bash(helm template:*)"
    ],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "theme": "dark-daltonized"
}
